{
  "name": "admin-manage",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/check-env.js",
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 vite",
    "dev:test": "cross-env NODE_OPTIONS=--max-old-space-size=4096 VITE_PROXY_TARGET=test vite",
    "dev:uat": "cross-env NODE_OPTIONS=--max-old-space-size=4096 VITE_PROXY_TARGET=uat vite",
    "serve": "pnpm dev",
    "build": "rimraf dist && rimraf node_modules/.vite && cross-env NODE_OPTIONS=--max-old-space-size=8192 vite build && generate-version-file",
    "build:safe": "npm run typecheck && rimraf dist && cross-env NODE_OPTIONS=--max-old-space-size=8192 vite build && generate-version-file",
    "build:staging": "rimraf dist && vite build --mode staging",
    "build:uat": "rimraf dist && vite build --mode uat",
    "build:prod": "rimraf dist && vite build --mode production",
    "report": "rimraf dist && vite build",
    "preview": "vite preview",
    "preview:build": "pnpm build && vite preview",
    "typecheck": "tsc --noEmit && vue-tsc --noEmit --skipLibCheck",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "svgo": "svgo -f . -r",
    "clean:cache": "rimraf .eslintcache && rimraf pnpm-lock.yaml && rimraf node_modules && pnpm store prune && pnpm install",
    "lint:eslint": "eslint --cache --max-warnings 0  \"{src,build}/**/*.{vue,js,ts,tsx}\" --fix",
    "lint:prettier": "prettier --write  \"src/**/*.{js,ts,json,tsx,css,scss,vue,html,md}\"",
    "lint:stylelint": "stylelint --cache --fix \"**/*.{html,vue,css,scss}\" --cache-location node_modules/.cache/stylelint/",
    "lint": "pnpm lint:eslint && pnpm lint:prettier && pnpm lint:stylelint",
    "prepare": "husky",
    "preinstall": "npx only-allow pnpm",
    "yalc-update": "yalc remove --all && yalc add yc-pro-components && yalc update && rm -rf node_modules && pnpm i && npm run dev"
  },
  "keywords": [
    "data-center-admin",
    "element-plus",
    "tailwindcss",
    "pure-admin",
    "typescript",
    "pinia",
    "vue3",
    "vite",
    "esm"
  ],
  "homepage": "https://cnb.cool/jinbizhihui/saas-platform-group",
  "repository": {
    "type": "git",
    "url": "git+https://cnb.cool/jinbizhihui/saas-platform-group/data-center-admin.git"
  },
  "bugs": {
    "url": "https://cnb.cool/jinbizhihui/saas-platform-group/data-center-admin/issues"
  },
  "license": "MIT",
