VITE_API_URL = http://192.168.177.116:8000
# VITE_API_URL = http://192.168.177.114:4399

# 默认应用ID
VITE_APP_ID = "6022711452170000"
# 预发布也需要生产环境的行为
# https://cn.vitejs.dev/guide/env-and-mode.html#modes
# NODE_ENV = development

VITE_PUBLIC_PATH = /data-center-admin/

# 预发布环境路由历史模式（Hash模式传"hash"、HTML5模式传"h5"、Hash模式带base参数传"hash,base参数"、HTML5模式带base参数传"h5,base参数"）
VITE_ROUTER_HISTORY = "h5"

# 是否在打包时使用cdn替换本地库 替换 true 不替换 false
VITE_CDN = false

# 是否启用gzip压缩或brotli压缩（分两种情况，删除原始文件和不删除原始文件）
# 压缩时不删除原始文件的配置：gzip、brotli、both（同时开启 gzip 与 brotli 压缩）、none（不开启压缩，默认）
# 压缩时删除原始文件的配置：gzip-clear、brotli-clear、both-clear（同时开启 gzip 与 brotli 压缩）、none（不开启压缩，默认）
VITE_COMPRESSION = "none"

# ============================================================================
# 微前端子应用配置（qiankun）
# ============================================================================

# 微前端子应用名称（需要与主应用配置中的 name 保持一致）
VITE_MICRO_APP_NAME = data-center-admin

# 微前端子应用激活路由（当主应用 URL 匹配此规则时，加载本子应用）
VITE_MICRO_ACTIVE_RULE = /data-center-admin
